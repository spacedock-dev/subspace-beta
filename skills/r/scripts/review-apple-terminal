#!/usr/bin/env bash
set -euo pipefail

invocation_name=apple-terminal
invocation_async=1
script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
# shellcheck source=invocation-common
source "$script_dir/invocation-common"

invocation_host_preflight() {
  [[ $(uname -s) == Darwin ]] || invocation_preflight_fail 'Apple Terminal requires macOS'
  app=/System/Applications/Utilities/Terminal.app
  [[ -d $app ]] || invocation_preflight_fail "Apple Terminal is unavailable at $app"
  [[ -x /usr/bin/osascript ]] || invocation_preflight_fail '/usr/bin/osascript is unavailable'
  [[ -x /usr/bin/plutil ]] || invocation_preflight_fail '/usr/bin/plutil is unavailable'
  local bundle status
  bundle=$(/usr/bin/plutil -extract CFBundleIdentifier raw -o - "$app/Contents/Info.plist" 2>/dev/null) || {
    status=$?
    invocation_preflight_fail "operation read bundle identity failed with status $status" "$status"
  }
  [[ $bundle == com.apple.Terminal ]] || \
    invocation_preflight_fail "Apple Terminal bundle id is $bundle, expected com.apple.Terminal"
  apple_script='on run argv
  set commandLine to "exec"
  repeat with argumentValue in argv
    set commandLine to commandLine & " " & quoted form of (argumentValue as text)
  end repeat
  tell application id "com.apple.Terminal"
    set reviewTab to do script commandLine
    activate
    return reviewTab
  end tell
end run'
}

invocation_host_dispatch() {
  local launch_output launch_status status_file=$invocation_dir/apple-terminal-status
  invocation_residue='; operation: do script'
  launch_output=$({
    /usr/bin/osascript -e "$apple_script" -- "$invocation_capsule" 2>&1
    printf '%s\n' "$?" > "$status_file"
  } | LC_ALL=C /usr/bin/head -c 4096)
  launch_status=$(<"$status_file")
  rm -f -- "$status_file"
  if [[ $launch_status != 0 ]]; then
    if [[ $launch_output == *-1743* ]]; then
      invocation_residue='; operation: do script; Apple Terminal Automation permission is required (-1743)'
    fi
    return "$launch_status"
  fi
}

invocation_main "$@"
