#!/usr/bin/env bash
set -euo pipefail

invocation_name=herdr
invocation_async=1
script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
# shellcheck source=invocation-common
source "$script_dir/invocation-common"

invocation_host_preflight() {
  [[ ${HERDR_ENV:-} == 1 ]] || invocation_preflight_fail 'HERDR_ENV=1 is required'
  caller_handle=${HERDR_PANE_ID:-}
  [[ -n $caller_handle ]] || invocation_preflight_fail 'HERDR_PANE_ID is required'
  herdr_bin=${SUBSPACE_HERDR_BIN:-herdr}
  if [[ $herdr_bin != */* ]]; then
    herdr_bin=$(command -v -- "$herdr_bin") || invocation_preflight_fail 'Herdr is not installed' 127
  fi
  [[ -x $herdr_bin && ! -d $herdr_bin ]] || invocation_preflight_fail "Herdr is not executable: $herdr_bin"
  jq_bin=$(command -v jq) || invocation_preflight_fail 'jq is required to validate Herdr identities' 127
  local caller_record status
  caller_record=$("$herdr_bin" pane get "$caller_handle" 2>/dev/null) || {
    status=$?
    invocation_preflight_fail "operation pane get failed with status $status" "$status"
  }
  caller=$("$jq_bin" -er '.result.pane.pane_id | select(type == "string" and length > 0)' <<< "$caller_record") || \
    invocation_preflight_fail 'caller pane did not resolve to one public identity'
}

invocation_host_dispatch() {
  local split_record split_status capsule_command
  invocation_residue='; operation: pane split'
  split_record=$("$herdr_bin" pane split "$caller" --direction right \
    --cwd "$invocation_artifact_dir" --no-focus 2>/dev/null)
  split_status=$?
  [[ $split_status == 0 ]] || return "$split_status"
  owned=$("$jq_bin" -er '.result.pane.pane_id | select(type == "string" and length > 0)' <<< "$split_record") || return 1
  [[ $owned != "$caller" ]] || return 1
  invocation_residue="; operation: pane run; possible pane: $owned"
  printf -v capsule_command 'exec %q' "$invocation_capsule"
  "$herdr_bin" pane run "$owned" "$capsule_command" >/dev/null 2>/dev/null
}

invocation_main "$@"
