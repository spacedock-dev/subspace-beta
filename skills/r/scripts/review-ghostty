#!/usr/bin/env bash
set -euo pipefail

invocation_name=ghostty
invocation_async=1
script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
# shellcheck source=invocation-common
source "$script_dir/invocation-common"

invocation_host_preflight() {
  [[ $(uname -s) == Darwin ]] || invocation_preflight_fail 'Ghostty requires macOS'
  app=${SUBSPACE_GHOSTTY_APP:-/Applications/Ghostty.app}
  [[ $app == /* ]] || invocation_preflight_fail "Ghostty app path must be absolute: $app"
  [[ -d $app ]] || invocation_preflight_fail "Ghostty is unavailable at $app"
  [[ -x /usr/bin/open ]] || invocation_preflight_fail '/usr/bin/open is unavailable'
  [[ -x /usr/bin/plutil ]] || invocation_preflight_fail '/usr/bin/plutil is unavailable'
  local plist bundle status
  plist=$app/Contents/Info.plist
  bundle=$(/usr/bin/plutil -extract CFBundleIdentifier raw -o - "$plist" 2>/dev/null) || {
    status=$?
    invocation_preflight_fail "operation read bundle identity failed with status $status" "$status"
  }
  [[ $bundle == com.mitchellh.ghostty ]] || \
    invocation_preflight_fail "Ghostty bundle id is $bundle, expected com.mitchellh.ghostty"
}

invocation_host_dispatch() {
  invocation_residue='; operation: open'
  /usr/bin/open -n -a "$app" --args -e "$invocation_capsule" >/dev/null 2>/dev/null
}

invocation_main "$@"
