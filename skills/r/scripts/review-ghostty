#!/usr/bin/env bash
set -euo pipefail

transport_name=ghostty
script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
# shellcheck source=transport-common
source "$script_dir/transport-common"

[[ $(uname -s) == Darwin ]] || transport_preflight_fail 'Ghostty requires macOS'
app=${SUBSPACE_GHOSTTY_APP:-/Applications/Ghostty.app}
[[ $app == /* ]] || transport_preflight_fail "Ghostty app path must be absolute: $app"
[[ -d $app ]] || transport_preflight_fail "Ghostty is unavailable at $app"
[[ -x /usr/bin/open ]] || transport_preflight_fail '/usr/bin/open is unavailable'
[[ -x /usr/bin/plutil ]] || transport_preflight_fail '/usr/bin/plutil is unavailable'
plist=$app/Contents/Info.plist
bundle=$(/usr/bin/plutil -extract CFBundleIdentifier raw -o - "$plist") || \
  transport_preflight_fail 'could not read the Ghostty bundle identity'
[[ $bundle == com.mitchellh.ghostty ]] || \
  transport_preflight_fail "Ghostty bundle id is $bundle, expected com.mitchellh.ghostty"
version=$(/usr/bin/plutil -extract CFBundleShortVersionString raw -o - "$plist") || \
  transport_preflight_fail 'could not read the Ghostty version'
[[ $version =~ ^([0-9]+)\.([0-9]+)(\.|$) ]] || transport_preflight_fail "cannot parse Ghostty version: $version"
major=${BASH_REMATCH[1]}
minor=${BASH_REMATCH[2]}
(( major > 1 || (major == 1 && minor >= 2) )) || \
  transport_preflight_fail "Ghostty 1.2 or newer is required; found $version"

transport_mark_dispatched
/usr/bin/open -n -a "$app" --args -e "$transport_capsule" || \
  transport_preserve_fail 'Ghostty launch was not accepted'

transport_receive
transport_deliver
