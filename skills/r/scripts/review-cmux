#!/usr/bin/env bash
set -euo pipefail

invocation_name=cmux
invocation_async=1
script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
# shellcheck source=invocation-common
source "$script_dir/invocation-common"

invocation_host_preflight() {
  cmux_bin=${SUBSPACE_CMUX_BIN:-cmux}
  if [[ $cmux_bin != */* ]]; then
    cmux_bin=$(command -v -- "$cmux_bin") || invocation_preflight_fail 'CMUX is not installed' 127
  fi
  [[ -x $cmux_bin && ! -d $cmux_bin ]] || invocation_preflight_fail "CMUX is not executable: $cmux_bin"
  jq_bin=$(command -v jq) || invocation_preflight_fail 'jq is required to validate CMUX identities' 127
  local identify status
  identify=$("$cmux_bin" identify --json 2>/dev/null) || {
    status=$?
    invocation_preflight_fail "operation identify failed with status $status" "$status"
  }
  workspace=$("$jq_bin" -er '.caller.workspace_ref | select(type == "string" and length > 0)' <<< "$identify") || \
    invocation_preflight_fail 'CMUX caller has no workspace identity'
  caller_pane=$("$jq_bin" -er '.caller.pane_ref | select(type == "string" and length > 0)' <<< "$identify") || \
    invocation_preflight_fail 'CMUX caller has no pane identity'
  caller_surface=$("$jq_bin" -er '.caller.surface_ref | select(type == "string" and length > 0)' <<< "$identify") || \
    invocation_preflight_fail 'CMUX caller has no surface identity'
}

invocation_host_dispatch() {
  local created create_status capsule_command
  invocation_residue='; operation: new-surface'
  created=$("$cmux_bin" new-surface --workspace "$workspace" --pane "$caller_pane" \
    --type terminal --working-directory "$invocation_artifact_dir" --focus true --json 2>/dev/null)
  create_status=$?
  [[ $create_status == 0 ]] || return "$create_status"
  surface=$("$jq_bin" -er '.surface_ref | select(type == "string" and length > 0)' <<< "$created") || return 1
  [[ $surface != "$caller_surface" ]] || return 1
  invocation_residue="; operation: respawn-pane; possible surface: $surface"
  printf -v capsule_command 'exec %q' "$invocation_capsule"
  "$cmux_bin" respawn-pane --surface "$surface" --command "$capsule_command" >/dev/null 2>/dev/null
}

invocation_host_complete() {
  local status
  "$cmux_bin" close-surface --surface "$surface" >/dev/null 2>/dev/null || {
    status=$?
    invocation_residue="; operation: close-surface; possible surface: $surface"
    invocation_preserve_fail "owned surface cleanup failed with status $status" "$status"
  }
  "$cmux_bin" focus-panel --workspace "$workspace" --panel "$caller_surface" >/dev/null 2>/dev/null || {
    status=$?
    invocation_residue="; operation: focus-panel; possible surface: $surface"
    invocation_preserve_fail "caller surface restoration failed with status $status" "$status"
  }
}

invocation_main "$@"
