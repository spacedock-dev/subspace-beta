#!/usr/bin/env bash
set -euo pipefail

invocation_name=zellij
invocation_async=0
script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
# shellcheck source=invocation-common
source "$script_dir/invocation-common"

invocation_host_preflight() {
  zellij_bin=${SUBSPACE_ZELLIJ_BIN:-zellij}
  if [[ $zellij_bin != */* ]]; then
    zellij_bin=$(command -v -- "$zellij_bin") || invocation_preflight_fail 'Zellij is not installed' 127
  fi
  [[ -x $zellij_bin && ! -d $zellij_bin ]] || invocation_preflight_fail "Zellij is not executable: $zellij_bin"
  jq_bin=$(command -v jq) || invocation_preflight_fail 'jq is required to validate the Zellij pane inventory' 127
  local inventory status
  session=${ZELLIJ_SESSION_NAME:-}
  pane=${ZELLIJ_PANE_ID:-}
  [[ -n $session ]] || invocation_preflight_fail 'ZELLIJ_SESSION_NAME is required'
  [[ $pane =~ ^[0-9]+$ ]] || invocation_preflight_fail 'numeric ZELLIJ_PANE_ID is required'
  inventory=$("$zellij_bin" --session "$session" action list-panes --json --tab --state 2>/dev/null) || {
    status=$?
    invocation_preflight_fail "operation list-panes failed with status $status" "$status"
  }
  tab_id=$("$jq_bin" -er --argjson pane "$pane" '
    def valid_row:
      type == "object" and
      (.id | type) == "number" and (.id | floor) == .id and
      (.is_plugin | type) == "boolean" and
      (.exited | type) == "boolean" and
      (.tab_id | type) == "number" and (.tab_id | floor) == .tab_id and .tab_id >= 0;
    if type != "array" or (all(.[]; valid_row) | not) then
      error("invalid pane inventory")
    else
      [.[] | select(.id == $pane and .is_plugin == false and .exited == false)] |
      if length == 1 then .[0].tab_id else error("caller pane is not uniquely live") end
    end
  ' <<< "$inventory") || invocation_preflight_fail "caller pane terminal_$pane is not uniquely live"
}

invocation_host_dispatch() {
  invocation_residue='; operation: new-pane'
  "$zellij_bin" --session "$session" action new-pane \
    --blocking --floating --close-on-exit \
    --tab-id "$tab_id" --cwd "$invocation_artifact_dir" -- \
    "$invocation_tui" --actor person:reviewer --result "$invocation_result" "$invocation_artifact" \
    >/dev/null 2>/dev/null
}

invocation_main "$@"
