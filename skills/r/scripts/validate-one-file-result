#!/usr/bin/env bash
set -euo pipefail

[[ $# == 4 ]] || {
  printf 'usage: validate-one-file-result <absolute-file.md> <sha256-revision> <absolute-result.json> <absolute-capture.json>\n' >&2
  exit 2
}
artifact=$1
revision=$2
result=$3
capture=$4

[[ $artifact == /* && $result == /* && $capture == /* ]] || exit 20
[[ -f $result && ! -L $result && -f $capture && ! -L $capture ]] || exit 20
[[ $revision =~ ^sha256:[[:xdigit:]]{64}$ ]] || exit 20
cmp -s -- "$result" "$capture" || exit 20

result_mode=$(stat -f '%Lp' "$result" 2>/dev/null || stat -c '%a' "$result" 2>/dev/null) || exit 20
[[ $result_mode == 600 ]] || exit 20
briefing_hash=$(printf 'subspace:one-file-invocation:v1\0%s' "$result" | shasum -a 256 | awk '{print $1}')
briefing=briefing:single-file:$(printf '%.32s' "$briefing_hash")

jq -s -e --arg artifact "$artifact" --arg revision "$revision" --arg briefing "$briefing" '
  def exact_keys($want): (keys | sort) == ($want | sort);
  def nonempty: type == "string" and length > 0;
  def selector:
    type == "object" and
    (all(keys[]; . == "type" or . == "exact" or . == "prefix" or . == "suffix")) and
    .type == "TextQuoteSelector" and (.exact | nonempty) and
    ((has("prefix") | not) or (.prefix | type == "string")) and
    ((has("suffix") | not) or (.suffix | type == "string"));
  def annotation:
    type == "object" and
    (all(keys[]; . == "type" or . == "id" or . == "briefing" or . == "by" or
      . == "at" or . == "target" or . == "selectors" or . == "kind" or
      . == "body" or . == "original" or . == "proposed")) and
    .type == "Annotation" and (.id | nonempty) and .briefing == $briefing and
    .by == "person:reviewer" and (.at | nonempty) and .target == "artifact:primary" and
    ((has("selectors") | not) or ((.selectors | type) == "array" and all(.selectors[]; selector))) and
    if .kind == "comment" then
      (.body | nonempty) and (has("original") | not) and (has("proposed") | not)
    elif .kind == "suggestion" then
      (.original | type == "string") and (.proposed | type == "string") and
      (.selectors | type == "array" and length > 0) and (has("body") | not)
    else false end;
  def artifact_identity:
    exact_keys(["id","uri","mediaType","rev"]) and
    . == {id:"artifact:primary",uri:$artifact,mediaType:"text/markdown",rev:$revision};
  def feedback:
    exact_keys(["type","status","briefing","artifact","annotations","actor"]) and
    .type == "review-v1-result" and .status == "feedback" and .briefing == $briefing and
    (.artifact | artifact_identity) and .actor == "person:reviewer" and
    (.annotations | type == "array") and all(.annotations[]; annotation) and
    (([.annotations[].id] | unique | length) == (.annotations | length));
  def open($root):
    exact_keys(["type","status","briefing","artifact","package","log"]) and
    .type == "review-v1-open-result" and .status == "open" and .briefing == $briefing and
    (.artifact | artifact_identity) and
    (.package | nonempty and startswith("/") and
      (split("/")[1:] | length > 0 and all(.[]; length > 0 and . != "." and . != ".."))) and
    (.log | nonempty and . == ($root.package + "/briefing.review.jsonl"));
  if length != 1 or (.[0] | type) != "object" then error("exactly one result object is required")
  else .[0] as $root |
    if ($root | feedback) or ($root | open($root)) then true
    else error("invalid one-file result") end
  end
' "$capture" >/dev/null

[[ $(head -c 1 "$capture") == '{' ]] || exit 20
last_byte=$(tail -c 1 "$capture" | od -An -t x1 | tr -d ' ')
if [[ $last_byte == 0a ]]; then
  [[ $(tail -c 2 "$capture" | head -c 1) == '}' ]] || exit 20
else
  [[ $last_byte == 7d ]] || exit 20
fi

if [[ $(jq -r '.status' "$capture") == open ]]; then
  package=$(jq -r '.package' "$capture")
  log=$(jq -r '.log' "$capture")
  [[ -d $package && ! -L $package ]] || exit 20
  package_mode=$(stat -f '%Lp' "$package" 2>/dev/null || stat -c '%a' "$package" 2>/dev/null) || exit 20
  [[ $package_mode == 700 ]] || exit 20
  briefing_path=$package/briefing.json
  snapshot_path=$package/artifact.md
  [[ -f $briefing_path && ! -L $briefing_path && -f $snapshot_path && ! -L $snapshot_path ]] || exit 20
  briefing_mode=$(stat -f '%Lp' "$briefing_path" 2>/dev/null || stat -c '%a' "$briefing_path" 2>/dev/null) || exit 20
  snapshot_mode=$(stat -f '%Lp' "$snapshot_path" 2>/dev/null || stat -c '%a' "$snapshot_path" 2>/dev/null) || exit 20
  [[ $briefing_mode == 600 && $snapshot_mode == 600 ]] || exit 20
  snapshot_revision=sha256:$(shasum -a 256 "$snapshot_path" | awk '{print $1}')
  [[ $snapshot_revision == "$revision" ]] || exit 20
  jq -s -e --arg briefing "$briefing" --arg artifact "$artifact" --arg revision "$revision" '
    length == 1 and (.[0] |
      type == "object" and (keys | sort) == (["type","version","id","question","artifacts","context"] | sort) and
      .type == "Briefing" and .version == "1" and .id == $briefing and
      .question == "What should the requester know about this artifact?" and .context == [] and
      .artifacts == [{id:"artifact:primary",uri:$artifact,mediaType:"text/markdown",rev:$revision}])
  ' "$briefing_path" >/dev/null
  if [[ -e $log || -L $log ]]; then
    [[ -s $log && -f $log && ! -L $log ]] || exit 20
    log_mode=$(stat -f '%Lp' "$log" 2>/dev/null || stat -c '%a' "$log" 2>/dev/null) || exit 20
    [[ $log_mode == 600 ]] || exit 20
    jq -s -e --arg briefing "$briefing" '
      def nonempty: type == "string" and length > 0;
      def selector: type == "object" and
        (all(keys[]; . == "type" or . == "exact" or . == "prefix" or . == "suffix")) and
        .type == "TextQuoteSelector" and (.exact | nonempty) and
        ((has("prefix") | not) or (.prefix | type == "string")) and
        ((has("suffix") | not) or (.suffix | type == "string"));
      def annotation: type == "object" and
        (all(keys[]; . == "type" or . == "id" or . == "briefing" or . == "by" or . == "at" or . == "target" or . == "selectors" or . == "kind" or . == "body" or . == "original" or . == "proposed")) and
        .type == "Annotation" and (.id | nonempty) and .briefing == $briefing and .by == "person:reviewer" and
        (.at | nonempty) and .target == "artifact:primary" and
        ((has("selectors") | not) or ((.selectors | type) == "array" and all(.selectors[]; selector))) and
        if .kind == "comment" then (.body | nonempty) and (has("original") | not) and (has("proposed") | not)
        elif .kind == "suggestion" then (.original | type == "string") and (.proposed | type == "string") and (.selectors | type == "array" and length > 0) and (has("body") | not)
        else false end;
      length > 0 and all(.[]; annotation) and (([.[].id] | unique | length) == length)
    ' "$log" >/dev/null
  fi
fi

cat -- "$capture"
